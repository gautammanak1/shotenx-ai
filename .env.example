# Required — Express API (local dev: http://localhost:8080; Docker Compose: http://backend:8080)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# Required for dashboard auth (Supabase project)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional — server-side Next routes (ASI1 prompt guard, llm-search proxy)
# ASI_ONE_API_KEY=
# ASI_ONE_BASE_URL=https://api.asi1.ai/v1
# ASI_ONE_MODEL=asi1

# Optional — Agentverse / uAgent (agent-chat API route)
# AGENTVERSE_TOKEN=
# UAGENT_DEFAULT_SEED=frontend
# UAGENT_BRIDGE_PORT=8000

# Optional — L402 / premium (set in production)
# ALBY_L402_SECRET=
# SHOTENX_PREMIUM_RELAY_SECRET=
# SHOTENX_DIRECT_CHAT_INTERNAL_SECRET=
