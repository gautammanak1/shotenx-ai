# =============================================================================
# ShotenX monorepo — ONE root `.env` for Docker Compose + local tooling
# Copy:  cp .env.example .env
# GitHub: https://github.com/gautammanak1 (set ALLOWED_ORIGINS to your real UI URL in prod)
# =============================================================================

# --- Docker / Compose (frontend build-arg uses backend hostname) ---
# When running `docker compose`, NEXT_PUBLIC_BACKEND_URL is overridden in compose.yml
# to http://backend:8080. For local `cd frontend && npm run dev`, use:
#   NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

NEXT_PUBLIC_BACKEND_URL=http://localhost:8080
NODE_ENV=development

# --- Frontend (Next) — public + server routes ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
ASI_ONE_API_KEY=
AGENTVERSE_TOKEN=
SHOTENX_PREMIUM_RELAY_SECRET=

# --- Backend (Express) ---
PORT=8080
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional JSON stores (inside container defaults under /app/data)
# PAYMENTS_DB_PATH=
# RATINGS_DB_PATH=

AGENTVERSE_BASE_URL=https://agentverse.ai
AGENTVERSE_API_KEY=

DEFAULT_L402_PRICE_SATS=25
MDK_ACCESS_TOKEN=
# SHOTENX_DIRECT_CHAT_INTERNAL_SECRET=

# ASI_ONE_BASE_URL=https://api.asi1.ai/v1
# ASI_ONE_MODEL=asi1
# ASI_IMAGE_MODEL=asi1-mini
# OPENAI_API_KEY=
# BUILDER_LLM_MODEL=
# BUILDER_IMAGE_MODEL=gpt-image-1

UAGENT_DEFAULT_SEED=frontend
# UAGENT_BRIDGE_PORT=8000

WITHDRAWAL_DESTINATION=
# ALBY_NWC_URL=
