{
  "name": "shotenx-ai-backend",
  "version": "0.1.0",
  "private": true,
  "description": "ShotenX AI backend for agent marketplace, Lightning payments, and A2A utilities",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:a2a": "tsx watch src/a2aServer.ts",
    "dev:all": "node scripts/dev-all.mjs",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:a2a": "node dist/a2aServer.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.13",
    "@getalby/sdk": "^7.0.0",
    "@webbtc/webln-types": "^3.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "mammoth": "^1.9.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^6.2.0",
    "pdf-parse": "^1.1.1",
    "uagent-client": "^1.0.10",
    "uuid": "^11.1.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.18.6",
    "@types/pdf-parse": "^1.1.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
